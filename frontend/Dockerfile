FROM node:20-alpine3.20 AS builder
WORKDIR /app
COPY package*.json ./
RUN npm config set fetch-retry-maxtimeout 600000 && \
    npm config set fetch-retries 10 && \
    npm config set maxsockets 3
RUN npm ci --legacy-peer-deps
COPY . .
ARG VITE_AUTH_SERVICE_URL=http://localhost:5001
ARG VITE_COMMUNITY_SERVICE_URL=http://localhost:3002
ARG VITE_COMPLAINT_SERVICE_URL=http://localhost:3003
ARG VITE_NOTIFICATION_SERVICE_URL=http://localhost:5004
ARG VITE_MESSAGING_SERVICE_URL=http://localhost:5005
ARG VITE_JOB_SERVICE_URL=http://localhost:5003
ARG VITE_CENTRIFUGO_URL=ws://localhost:8000/connection/websocket
ARG VITE_GOOGLE_CLIENT_ID
ARG VITE_APP_NAME=LaborGuard
ARG VITE_DEFAULT_LANGUAGE=en

ENV VITE_AUTH_SERVICE_URL=$VITE_AUTH_SERVICE_URL
ENV VITE_COMMUNITY_SERVICE_URL=$VITE_COMMUNITY_SERVICE_URL
ENV VITE_COMPLAINT_SERVICE_URL=$VITE_COMPLAINT_SERVICE_URL
ENV VITE_NOTIFICATION_SERVICE_URL=$VITE_NOTIFICATION_SERVICE_URL
ENV VITE_MESSAGING_SERVICE_URL=$VITE_MESSAGING_SERVICE_URL
ENV VITE_JOB_SERVICE_URL=$VITE_JOB_SERVICE_URL
ENV VITE_CENTRIFUGO_URL=$VITE_CENTRIFUGO_URL
ENV VITE_GOOGLE_CLIENT_ID=$VITE_GOOGLE_CLIENT_ID
ENV VITE_APP_NAME=$VITE_APP_NAME
ENV VITE_DEFAULT_LANGUAGE=$VITE_DEFAULT_LANGUAGE

RUN npm run build

FROM nginx:1.27-alpine3.20 AS production
RUN rm /etc/nginx/conf.d/default.conf
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]