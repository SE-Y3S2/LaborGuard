# ─────────────────────────────────────────────────────────────────────────────
# LaborGuard – Backend Shared Environment Variables  (TEMPLATE – safe to commit)
# Copy this file to .env and fill in real values.
# The real .env is git-ignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas — replace with your own cluster connection string
MONGODB_ATLAS_BASE=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=LaborGuard

# General
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
SESSION_SECRET=replace_with_another_long_random_secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback

# Cloudinary (used by community-service)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# OpenAI (used by community-service for moderation)
OPENAI_API_KEY=your-openai-api-key
